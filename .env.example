# Kopiere diese Datei zu  .env  (das echte .env wird NIE committet — siehe .gitignore)
# und trage deine echten Tokens ein. Nie in Screenshots/Chats teilen.

# Bright Data — für tools/fetch_airbnb.py --fetch (Airbnb-Konkurrenz-Daten)
BRIGHTDATA_API_KEY=

# Brave Search — für tools/fetch_competitors.py (optional)
BRAVE_SEARCH_TOKEN=
