.DS_Store
Thumbs.db
*.swp
*.tmp
*~

# Editor / IDE
.vscode/
.idea/
*.iml

# Claude / agent local state (per-machine, not shared)
.claude/

# Python cache from data refresh tools
__pycache__/
*.pyc
.python-version
.venv/
venv/

# Local runs / scratch
scratch/
*.log

# Secrets — API-Tokens, nie committen (z.B. BRIGHTDATA_API_KEY)
.env
.env.*
!.env.example

# Bright-Data-Rohexporte (gross, ungetrimmt) — nur das getrimmte data/*.json wird committet
data/raw/

# InsideAirbnb-Rohdownloads (externe Ground-Truth-CSVs, gross) — lokal als Cross-Check,
# erst nach Verdrahtung als getrimmtes data/*.json committen
data/insideairbnb/

# Cockpit-Snapshots (data/snapshots/) werden BEWUSST COMMITTET — siehe data/snapshots/README.md.
# Unterschied zu data/raw/: Roh-Scrapes sind REGENERIERBAR (neu scrapen geht), die täglichen
# Kalender-Snapshots sind UNWIEDERBRINGLICH (ein vergangener Tag lässt sich nie mehr holen).
# Darum: best geschützt, off-machine in GitHub, versioniert. ~30 KB/Tag/Gemeinde.

# Postfach-Inserate (Gmail-Suchagent) - Vermieter-Namen/Objekte, NICHT ins public Repo
data/briefing-postfach.local.json
data/*.local.json
